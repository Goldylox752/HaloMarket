// ============================================
// HALO MARKETPLACE DATABASE
// schema.prisma
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

// ============================================
// USERS
// ============================================

model User {

  id            String   @id @default(cuid())

  firstName     String

  lastName      String

  email         String   @unique

  password      String

  role          Role     @default(BUYER)

  avatar        String?

  verified      Boolean  @default(false)

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt

  store         Store?

  orders        Order[]

  reviews       Review[]

}

// ============================================
// STORES
// ============================================

model Store {

  id            String   @id @default(cuid())

  name          String

  slug          String   @unique

  description   String?

  logo          String?

  banner        String?

  ownerId       String   @unique

  owner         User     @relation(fields:[ownerId], references:[id])

  products      Product[]

  plan          SubscriptionPlan @default(FREE)

  createdAt     DateTime @default(now())

}

// ============================================
// CATEGORIES
// ============================================

model Category {

  id          String @id @default(cuid())

  name        String

  slug        String @unique

  products    Product[]

}

// ============================================
// PRODUCTS
// ============================================

model Product {

  id            String @id @default(cuid())

  title         String

  slug          String @unique

  description   String

  price         Decimal

  inventory     Int

  image         String?

  status        ProductStatus @default(DRAFT)

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt

  storeId       String

  store         Store @relation(fields:[storeId], references:[id])

  categoryId    String

  category      Category @relation(fields:[categoryId], references:[id])

  reviews       Review[]

}

// ============================================
// ORDERS
// ============================================

model Order {

  id            String @id @default(cuid())

  buyerId       String

  buyer         User @relation(fields:[buyerId], references:[id])

  total         Decimal

  status        OrderStatus @default(PENDING)

  createdAt     DateTime @default(now())

}

// ============================================
// REVIEWS
// ============================================

model Review {

  id            String @id @default(cuid())

  rating        Int

  comment       String

  createdAt     DateTime @default(now())

  userId        String

  productId     String

  user          User @relation(fields:[userId], references:[id])

  product       Product @relation(fields:[productId], references:[id])

}
