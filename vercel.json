n{
  "version": 2,

  "functions": {
    "server.js": {
      "runtime": "@vercel/node"
    }
  },

  "routes": [
    {
      "src": "/api/webhooks/stripe",
      "dest": "/server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
